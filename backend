function doGet() {
  return HtmlService.createHtmlOutputFromFile('index')
      .setTitle('DoubleBook - GAS 통합 가계부')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function getSheet(name) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName(name);
  if (!sheet) {
    sheet = ss.insertSheet(name);
    if (name === 'Transactions') {
      sheet.appendRow(['id', 'date', 'debits', 'credits', 'memo']);
    } else if (name === 'Settings') {
      sheet.appendRow(['key', 'value']);
    } else if (name === 'Budgets') {
      // Budgets(예산) 시트가 없을 경우 헤더 생성 로직 추가
      sheet.appendRow(['id', 'yearMonth', 'account', 'content', 'amount']);
    }
  }
  return sheet;
}

function getAllData() {
  const settingsSheet = getSheet('Settings');
  const transSheet = getSheet('Transactions');
  const budgetSheet = getSheet('Budgets'); // 예산 시트 불러오기 추가
  
  const settingsRaw = settingsSheet.getDataRange().getValues();
  const transRaw = transSheet.getDataRange().getValues();
  const budgetRaw = budgetSheet.getDataRange().getValues(); // 예산 데이터
  
  let initialSetup = { debits: [{ account: '현금', amount: 0 }], credits: [] };
  let accounts = {
    assets: [{ id: 'a1', name: '현금', subtype: 'fixed' }],
    liabilities: [{ id: 'l1', name: '신용카드', subtype: 'variable' }, { id: 'e1', name: '이익잉여금', subtype: 'fixed' }],
    revenue: [{ id: 'r1', name: '급여', subtype: 'fixed' }],
    expenses: [{ id: 'x1', name: '식비', subtype: 'variable' }]
  };
  
  if (settingsRaw.length > 1) {
    settingsRaw.forEach(row => {
      if (row[0] === 'initialSetup') initialSetup = JSON.parse(row[1]);
      if (row[0] === 'accounts') accounts = JSON.parse(row[1]);
    });
  }
  
  const transactions = [];
  if (transRaw.length > 1) {
    for (let i = 1; i < transRaw.length; i++) {
      try {
        transactions.push({
          id: String(transRaw[i][0]),
          date: transRaw[i][1] instanceof Date ? Utilities.formatDate(transRaw[i][1], Session.getScriptTimeZone(), 'yyyy-MM-dd') : transRaw[i][1],
          debits: JSON.parse(transRaw[i][2]),
          credits: JSON.parse(transRaw[i][3]),
          memo: transRaw[i][4]
        });
      } catch (e) { console.error("Data parse error", e); }
    }
  }

  // 예산 데이터 파싱 로직 추가
  const budgets = [];
  if (budgetRaw.length > 1) {
    for (let i = 1; i < budgetRaw.length; i++) {
      budgets.push({
        id: String(budgetRaw[i][0]),
        yearMonth: String(budgetRaw[i][1]),
        account: String(budgetRaw[i][2]),
        content: String(budgetRaw[i][3]),
        amount: Number(budgetRaw[i][4]) || 0
      });
    }
  }

  return { initialSetup, accounts, transactions, budgets };
}

// 예산 데이터만 별도로 저장하는 함수
function saveBudgetData(yearMonth, currentMonthBudgets) {
  const sheet = getSheet('Budgets');
  const data = sheet.getDataRange().getValues();
  
  let newData = [data[0]]; 
  for (let i = 1; i < data.length; i++) {
    if (data[i][1] !== yearMonth) {
      newData.push(data[i]);
    }
  }
  
  currentMonthBudgets.forEach(b => {
    let newId = b.id || ('B-' + new Date().getTime() + Math.floor(Math.random() * 1000));
    newData.push([newId, b.yearMonth, b.account, b.content, b.amount]);
  });
  
  sheet.clear();
  sheet.getRange(1, 1, newData.length, newData[0].length).setValues(newData);
  
  return true;
}

function syncAllDataToSheet(data) {
  const { initialSetup, accounts, transactions } = data;
  
  // 1. Settings 시트 일괄 저장
  const settingsSheet = getSheet('Settings');
  settingsSheet.clear();
  
  const settingsData = [
    ['key', 'value'],
    ['initialSetup', JSON.stringify(initialSetup)],
    ['accounts', JSON.stringify(accounts)]
  ];
  
  settingsSheet.getRange(1, 1, settingsData.length, settingsData[0].length).setValues(settingsData);
  
  // 2. Transactions 시트 일괄 저장
  const transSheet = getSheet('Transactions');
  transSheet.clear();
  
  const header = ['id', 'date', 'debits', 'credits', 'memo'];
  let transData = [header];
  
  if (transactions && transactions.length > 0) {
    const bodyRows = transactions.map(t => [
      t.id, 
      t.date, 
      JSON.stringify(t.debits), 
      JSON.stringify(t.credits), 
      t.memo
    ]);
    transData = transData.concat(bodyRows);
  }
  
  transSheet.getRange(1, 1, transData.length, transData[0].length).setValues(transData);
  
  return true;
}
