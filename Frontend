<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>DoubleBook - GAS 통합 가계부</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    input[type="number"] { -moz-appearance: textfield; }
    .loading-overlay { background: rgba(255, 255, 255, 0.9); position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; flex-direction: column; }
  </style>
</head>
<body class="bg-slate-100 text-slate-800 font-sans">
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useMemo } = React;

    // --- 통신 모듈 (GAS & 로컬 Mock Data) ---
    const server = {
      getAllData: () => new Promise(resolve => {
        if (typeof google !== 'undefined' && google.script) {
          google.script.run.withSuccessHandler(resolve).getAllData();
        } else {
          // Canvas 미리보기를 위한 초기 Mock 데이터
          resolve({
            accounts: {
              expenses: [
                { id: 'e1', name: '식비' }, { id: 'e2', name: '교통비' }, 
                { id: 'e3', name: '문화생활비' }, { id: 'e4', name: '교육비' }
              ]
            },
            transactions: [
              { id: 't1', date: '2026-03-05', debits: [{ account: '교육비', amount: 15540 }], credits: [], memo: '책 스캔비용' },
              { id: 't2', date: '2026-03-07', debits: [{ account: '문화생활비', amount: 19000 }], credits: [], memo: '스팀 게임 구입' },
              { id: 't3', date: '2026-03-15', debits: [{ account: '식비', amount: 44200 }], credits: [], memo: '하늘초밥 데이트' },
              { id: 't4', date: '2026-03-18', debits: [{ account: '교통비', amount: 3000 }], credits: [], memo: '주차비 정산' }
            ],
            budgets: [
              { id: 'b1', yearMonth: '2026-03', account: '식비', content: '데이트 및 외식', amount: 300000 },
              { id: 'b2', yearMonth: '2026-03', account: '교육비', content: '도서 구입', amount: 50000 }
            ]
          });
        }
      }),
      saveBudgetData: (yearMonth, currentMonthBudgets) => new Promise((resolve, reject) => {
        if (typeof google !== 'undefined' && google.script) {
          google.script.run.withSuccessHandler(resolve).withFailureHandler(reject).saveBudgetData(yearMonth, currentMonthBudgets);
        } else {
          setTimeout(() => resolve(true), 500); // Mock delay
        }
      })
    };

    // --- 예산내역 (Budget) 컴포넌트 ---
    const BudgetPage = ({ accounts, transactions, budgets, onSave }) => {
      // 1. 연/월 상태 (기본값: 2026년 3월)
      const [targetMonth, setTargetMonth] = useState('2026-03');
      const [localBudgets, setLocalBudgets] = useState([]);
      const [expandedAccounts, setExpandedAccounts] = useState({});
      const [isSaving, setIsSaving] = useState(false);

      // 계정과목 목록 (Expense 전용)
      const expenseAccounts = accounts?.expenses?.map(e => e.name) || [];

      // targetMonth 변경 시 해당 월 예산 불러오기
      useEffect(() => {
        const monthBudgets = budgets.filter(b => b.yearMonth === targetMonth);
        setLocalBudgets(monthBudgets);
        setExpandedAccounts({}); // 월 변경시 아코디언 닫기
      }, [targetMonth, budgets]);

      // --- 예산 입력 핸들러 ---
      const handleAddRow = () => {
        setLocalBudgets([...localBudgets, { id: '', yearMonth: targetMonth, account: expenseAccounts[0] || '', content: '', amount: 0 }]);
      };
      const handleRemoveRow = (index) => {
        setLocalBudgets(localBudgets.filter((_, i) => i !== index));
      };
      const handleChangeRow = (index, field, value) => {
        const newB = [...localBudgets];
        newB[index][field] = field === 'amount' ? (Number(value) || 0) : value;
        setLocalBudgets(newB);
      };

      const handleSave = async () => {
        setIsSaving(true);
        try {
          await server.saveBudgetData(targetMonth, localBudgets);
          alert('예산내역이 저장되었습니다.');
          onSave(); // 부모 컴포넌트 데이터 갱신
        } catch(e) {
          alert('저장 실패');
        }
        setIsSaving(false);
      };

      // --- 실제 지출내역(Actuals) 계산 ---
      const actualsByAccount = useMemo(() => {
        const monthlyTx = transactions.filter(t => t.date.startsWith(targetMonth));
        let map = {};
        
        monthlyTx.forEach(tx => {
          // 차변(Debits)에 비용 계정이 있으면 지출 증가
          (tx.debits || []).forEach(d => {
            if (expenseAccounts.includes(d.account)) {
              if (!map[d.account]) map[d.account] = [];
              map[d.account].push({ date: tx.date, memo: tx.memo, amount: d.amount });
            }
          });
          // 대변(Credits)에 비용 계정이 있으면 지출 취소(마이너스)
          (tx.credits || []).forEach(c => {
            if (expenseAccounts.includes(c.account)) {
              if (!map[c.account]) map[c.account] = [];
              map[c.account].push({ date: tx.date, memo: tx.memo, amount: -c.amount });
            }
          });
        });

        // 날짜 오름차순 정렬 (초일 -> 말일)
        Object.keys(map).forEach(acc => {
          map[acc].sort((a, b) => a.date.localeCompare(b.date));
        });

        return map;
      }, [transactions, targetMonth, expenseAccounts]);

      const toggleAccordion = (accountName) => {
        setExpandedAccounts(prev => ({ ...prev, [accountName]: !prev[accountName] }));
      };

      // --- 화면 렌더링을 위한 계정 리스트업 (예산이 있거나 지출이 있는 계정) ---
      const combinedAccountNames = Array.from(new Set([
        ...localBudgets.map(b => b.account),
        ...Object.keys(actualsByAccount)
      ])).sort();

      let totalGlobalBudget = 0;
      let totalGlobalActual = 0;

      return (
        <div className="max-w-4xl mx-auto space-y-6 animate-fade-in">
          {/* 상단 컨트롤: 연/월 선택 */}
          <div className="bg-white p-4 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-between">
            <h2 className="text-xl font-bold text-slate-800">예산 및 지출 관리</h2>
            <input 
              type="month" 
              value={targetMonth} 
              onChange={(e) => setTargetMonth(e.target.value)}
              className="px-4 py-2 bg-slate-100 rounded-xl font-bold border-none outline-none focus:ring-2 focus:ring-indigo-500"
            />
          </div>

          {/* 예산 내역 입력 폼 */}
          <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200">
            <div className="flex justify-between items-center mb-4">
              <h3 className="text-lg font-bold text-slate-700">이번 달 예산 설정</h3>
              <button onClick={handleAddRow} className="flex items-center gap-1 text-sm bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 py-1.5 rounded-lg font-semibold transition">
                <i data-lucide="plus" className="w-4 h-4"></i> 행 추가
              </button>
            </div>

            <div className="space-y-2">
              {localBudgets.length === 0 && <p className="text-slate-400 text-sm text-center py-4">설정된 예산이 없습니다.</p>}
              {localBudgets.map((budget, i) => (
                <div key={i} className="flex flex-wrap sm:flex-nowrap gap-2 items-center">
                  <select 
                    value={budget.account} 
                    onChange={e => handleChangeRow(i, 'account', e.target.value)}
                    className="flex-1 sm:w-1/4 p-2 rounded-lg bg-slate-50 border border-slate-200 outline-none focus:border-indigo-500 text-sm font-medium"
                  >
                    <option value="">계정 선택</option>
                    {expenseAccounts.map(acc => <option key={acc} value={acc}>{acc}</option>)}
                  </select>
                  <input 
                    type="text" 
                    placeholder="예산 내용" 
                    value={budget.content} 
                    onChange={e => handleChangeRow(i, 'content', e.target.value)}
                    className="flex-1 sm:w-2/4 p-2 rounded-lg bg-slate-50 border border-slate-200 outline-none focus:border-indigo-500 text-sm"
                  />
                  <input 
                    type="number" 
                    placeholder="금액" 
                    value={budget.amount || ''} 
                    onChange={e => handleChangeRow(i, 'amount', e.target.value)}
                    className="flex-1 sm:w-1/4 p-2 rounded-lg bg-slate-50 border border-slate-200 outline-none focus:border-indigo-500 text-sm font-bold text-right"
                  />
                  <button onClick={() => handleRemoveRow(i)} className="p-2 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition">
                    <i data-lucide="trash-2" className="w-5 h-5"></i>
                  </button>
                </div>
              ))}
            </div>

            <div className="mt-4 flex justify-end">
              <button 
                onClick={handleSave} 
                disabled={isSaving}
                className="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-400 text-white px-5 py-2.5 rounded-xl font-bold transition shadow-md active:scale-95"
              >
                <i data-lucide="save" className="w-4 h-4"></i>
                {isSaving ? '저장 중...' : '예산내역 저장'}
              </button>
            </div>
          </div>

          {/* 실제 지출 내역 표시 (아코디언 형태) */}
          <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 space-y-4">
            <h3 className="text-lg font-bold text-slate-700 mb-2">예산 대비 지출내역 비교</h3>
            
            {combinedAccountNames.length === 0 && <p className="text-slate-400 text-sm text-center py-8">해당 월의 예산 및 지출 데이터가 없습니다.</p>}

            <div className="space-y-3">
              {combinedAccountNames.map(account => {
                const totalBudget = localBudgets.filter(b => b.account === account).reduce((sum, b) => sum + b.amount, 0);
                const actualLines = actualsByAccount[account] || [];
                const totalActual = actualLines.reduce((sum, line) => sum + line.amount, 0);
                const remaining = totalBudget - totalActual;
                
                totalGlobalBudget += totalBudget;
                totalGlobalActual += totalActual;
                
                const isExpanded = !!expandedAccounts[account];

                return (
                  <div key={account} className="border border-slate-200 rounded-xl overflow-hidden transition-all shadow-sm">
                    {/* 아코디언 헤더 */}
                    <div 
                      onClick={() => toggleAccordion(account)}
                      className="flex flex-wrap sm:flex-nowrap justify-between items-center p-3 sm:p-4 bg-slate-50 hover:bg-slate-100 cursor-pointer transition select-none"
                    >
                      <div className="flex items-center gap-3 w-full sm:w-auto mb-2 sm:mb-0">
                        <span className="font-extrabold text-slate-800">{account}</span>
                        <span className={`text-xs px-2 py-0.5 rounded-full font-bold ${remaining < 0 ? 'bg-red-100 text-red-600' : 'bg-emerald-100 text-emerald-700'}`}>
                          {remaining < 0 ? '예산 초과' : '안정적'}
                        </span>
                      </div>
                      <div className="flex items-center gap-4 sm:gap-6 text-sm flex-1 sm:flex-none justify-between sm:justify-end">
                        <div className="text-right">
                          <p className="text-slate-400 text-[10px] font-bold uppercase">예산</p>
                          <p className="font-semibold text-slate-600">{totalBudget.toLocaleString()}원</p>
                        </div>
                        <div className="text-right">
                          <p className="text-slate-400 text-[10px] font-bold uppercase">지출액</p>
                          <p className="font-bold text-slate-800">{totalActual.toLocaleString()}원</p>
                        </div>
                        <div className="w-8 flex justify-end text-slate-400">
                          {isExpanded ? <i data-lucide="chevron-up"></i> : <i data-lucide="chevron-down"></i>}
                        </div>
                      </div>
                    </div>

                    {/* 아코디언 바디 (상세 내역 - 왼쪽부터: 과목(생략/상단표기), 날짜, 내역, 금액 순) */}
                    {isExpanded && (
                      <div className="border-t border-slate-200 bg-white">
                        {actualLines.length > 0 ? (
                          <div className="p-3">
                            <table className="w-full text-left text-sm">
                              <thead className="text-slate-400 text-xs border-b border-slate-100">
                                <tr>
                                  <th className="py-2 w-28">날짜</th>
                                  <th className="py-2">거래내역</th>
                                  <th className="py-2 text-right w-32">금액</th>
                                </tr>
                              </thead>
                              <tbody className="divide-y divide-slate-50">
                                {actualLines.map((line, idx) => (
                                  <tr key={idx} className="hover:bg-slate-50 transition">
                                    <td className="py-2.5 text-slate-500">{line.date}</td>
                                    <td className="py-2.5 text-slate-700 font-medium">{line.memo || '내역 없음'}</td>
                                    <td className="py-2.5 text-right font-semibold text-slate-800">{line.amount.toLocaleString()}원</td>
                                  </tr>
                                ))}
                              </tbody>
                            </table>
                          </div>
                        ) : (
                          <div className="p-4 text-center text-sm text-slate-400">이번 달 해당 계정의 지출 내역이 없습니다.</div>
                        )}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>

            {/* 최하단 총합 표기 */}
            <div className="mt-6 pt-5 border-t-2 border-slate-200 flex justify-between items-center bg-indigo-50 p-4 rounded-xl">
              <h3 className="text-lg font-black text-indigo-900">모든 예산 및 지출 합계</h3>
              <div className="flex gap-6 text-right">
                <div>
                  <p className="text-indigo-400 text-xs font-bold">총 예산</p>
                  <p className="font-bold text-indigo-800">{totalGlobalBudget.toLocaleString()}원</p>
                </div>
                <div>
                  <p className="text-indigo-400 text-xs font-bold">총 지출액</p>
                  <p className="text-xl font-black text-indigo-600">{totalGlobalActual.toLocaleString()}원</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      );
    };

    // --- Main App ---
    const App = () => {
      const [loading, setLoading] = useState(true);
      const [data, setData] = useState(null);
      const [activeTab, setActiveTab] = useState('budget'); // 초기 탭을 예산내역으로 설정

      const loadData = async () => {
        setLoading(true);
        const fetchedData = await server.getAllData();
        setData(fetchedData);
        setLoading(false);
        setTimeout(() => lucide.createIcons(), 100);
      };

      useEffect(() => { loadData(); }, []);

      if (loading || !data) {
        return <div className="loading-overlay"><div className="animate-spin rounded-full h-10 w-10 border-b-2 border-indigo-600"></div><p className="mt-3 font-bold text-slate-600">장부 데이터를 불러오는 중...</p></div>;
      }

      return (
        <div className="min-h-screen flex flex-col">
          {/* Header & Navigation */}
          <header className="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-10">
            <div className="max-w-4xl mx-auto px-4 py-3 flex flex-wrap items-center justify-between">
              <h1 className="text-xl font-black text-indigo-600 flex items-center gap-2">
                <i data-lucide="book-open" className="w-6 h-6"></i> DoubleBook
              </h1>
              <nav className="flex gap-2 sm:gap-4 overflow-x-auto mt-3 sm:mt-0 w-full sm:w-auto pb-1 sm:pb-0 hide-scrollbar">
                {['entry', 'ledger', 'budget'].map(tab => (
                  <button 
                    key={tab}
                    onClick={() => { setActiveTab(tab); setTimeout(() => lucide.createIcons(), 50); }}
                    className={`px-3 py-1.5 sm:px-4 sm:py-2 rounded-xl text-sm font-bold whitespace-nowrap transition-colors ${activeTab === tab ? 'bg-indigo-100 text-indigo-700' : 'text-slate-500 hover:bg-slate-100'}`}
                  >
                    {tab === 'entry' && '전표입력'}
                    {tab === 'ledger' && '총계정원장'}
                    {tab === 'budget' && '예산내역'}
                  </button>
                ))}
              </nav>
            </div>
          </header>

          {/* Main Content Area */}
          <main className="flex-1 p-4 sm:p-6 w-full">
            {activeTab === 'budget' && (
              <BudgetPage 
                accounts={data.accounts} 
                transactions={data.transactions} 
                budgets={data.budgets || []} 
                onSave={loadData} 
              />
            )}
            {activeTab === 'entry' && <div className="text-center py-20 text-slate-400 font-bold">전표입력 페이지 (기존 기능 유지)</div>}
            {activeTab === 'ledger' && <div className="text-center py-20 text-slate-400 font-bold">총계정원장 페이지 (기존 기능 유지)</div>}
          </main>
        </div>
      );
    };

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
